{
  "expo": {
    "name": "Veribee Delivery",
    "slug": "veribee",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "veribee",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "icon": "./assets/images/veribee-app-icon.png",
    "splash": {
      "image": "./assets/images/veribee-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#fcf9f8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.veribee.delivery",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Veribee uses your location during active deliveries so buyers can see secure rider progress."
      }
    },
    "android": {
      "package": "com.veribee.delivery",
      "versionCode": 6,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/veribee-app-icon.png",
        "backgroundColor": "#fcf9f8"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/veribee-app-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "./node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/MaterialIcons.ttf"
          ]
        }
      ],
      "expo-asset",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Veribee uses your location during active deliveries so buyers can see secure rider progress."
        }
      ],
      "@maplibre/maplibre-react-native"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "8bc866e6-c5f8-4cda-a78e-a656cc64436d"
      }
    },
    "owner": "razaele0003"
  }
}
